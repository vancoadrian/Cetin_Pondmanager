RYBOLOV_ENVIRONMENT=development
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_REZERVACIE_PHONE="+421 911 298 702"

# Voliteľne nastav, ak lokálne JSON stores majú bežať na perzistentnom volume.
RYBOLOV_LOCAL_DATA_DIR=

# Weather provider pre snapshot pri úlovku.
# Možnosti: mock, station, manual, weather-api, disabled.
RYBOLOV_WEATHER_PROVIDER=mock
RYBOLOV_WEATHER_FALLBACK_TO_MOCK=true

# Budúce napojenie na externú meteoslužbu.
RYBOLOV_WEATHER_API_ENDPOINT=https://archive-api.open-meteo.com/v1/archive
RYBOLOV_WEATHER_API_KEY=
RYBOLOV_WEATHER_LATITUDE=
RYBOLOV_WEATHER_LONGITUDE=
RYBOLOV_WEATHER_TIMEOUT_MS=5000
RYBOLOV_WEATHER_WATER_TEMP_OFFSET_C=0

# Hodnoty pre station/manual provider, ak meteostanica alebo správca posiela aktuálny snapshot.
RYBOLOV_WEATHER_CONDITION=
RYBOLOV_WEATHER_AIR_TEMP_C=
RYBOLOV_WEATHER_WATER_TEMP_C=
RYBOLOV_WEATHER_PRESSURE_HPA=
RYBOLOV_WEATHER_PRESSURE_TREND=stable
RYBOLOV_WEATHER_WIND_KPH=
RYBOLOV_WEATHER_WIND_DIRECTION=
RYBOLOV_WEATHER_CLOUD_COVER_PCT=

# Doručovanie interných reportov. Mock iba pripraví e-mailový draft v lokálnom logu.
# Možnosti: mock, resend, disabled.
RYBOLOV_REPORT_DELIVERY_PROVIDER=mock
RYBOLOV_REPORT_EMAIL_FROM="Rybolov Cetín <reports@rybolov-cetin.local>"
RYBOLOV_REPORT_EMAIL_REPLY_TO=
RYBOLOV_RESEND_API_ENDPOINT=https://api.resend.com/emails
RYBOLOV_RESEND_API_KEY=

# Obnova hesla rybárskych účtov. Mock nikdy nezobrazí ani neuloží čitateľný reset token.
# Pre funkčné e-maily nastav resend a overeného odosielateľa v Resende.
# Možnosti: mock, resend, disabled.
RYBOLOV_AUTH_DELIVERY_PROVIDER=mock
RYBOLOV_AUTH_EMAIL_FROM="Rybolov Cetín <ucet@rybolov-cetin.local>"
RYBOLOV_AUTH_EMAIL_REPLY_TO=

# Doručovanie potvrdení rezervácií. Mock iba pripraví draft v administrácii.
# Možnosti: mock, resend, disabled.
RYBOLOV_RESERVATION_DELIVERY_PROVIDER=mock
RYBOLOV_RESERVATION_EMAIL_FROM="Rybolov Cetín <rezervacie@rybolov-cetin.local>"
RYBOLOV_RESERVATION_EMAIL_REPLY_TO=

# Secret pre serverless/hosting cron volanie endpointu /api/cron/catch-reports/run-due.
# Posiela sa ako Authorization: Bearer <secret> alebo x-rybolov-cron-secret.
RYBOLOV_REPORT_SCHEDULER_SECRET=

# Web Push bude v prototype fungovať aj bez VAPID ako lokálny mock odber.
# Pre reálne odosielanie nastav RYBOLOV_PUSH_PROVIDER=web-push a doplň VAPID kľúče.
# Kľúče vygeneruješ lokálne cez `pnpm push:vapid`.
RYBOLOV_PUSH_PROVIDER=mock
NUXT_PUBLIC_VAPID_PUBLIC_KEY=
RYBOLOV_VAPID_PRIVATE_KEY=
RYBOLOV_PUSH_SUBJECT=mailto:spravca@rybolov-cetin.local
RYBOLOV_PUSH_TTL_SECONDS=3600
RYBOLOV_PUSH_TIMEOUT_MS=10000
RYBOLOV_PUSH_URGENCY=normal
