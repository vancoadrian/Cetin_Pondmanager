{
  "name": "rybolov-cetin",
  "version": "0.1.0",
  "private": true,
  "description": "Rybolov Cetín — PWA pre rybársky revír Štrkovisko Kocka a Veľký Cetín",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "local:setup": "node scripts/setup-local-env.ts",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "push:vapid": "node scripts/generate-vapid-keys.ts",
    "seed:export": "node scripts/export-supabase-seed.ts",
    "supabase:reset": "supabase db reset",
    "supabase:start": "supabase start -x logflare,vector,imgproxy,edge-runtime --ignore-health-check",
    "supabase:stop": "supabase stop",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:lhci": "lhci autorun --config=lighthouserc.cjs"
  },
  "dependencies": {
    "@nuxt/ui": "^3.0.0",
    "@vite-pwa/nuxt": "^1.0.0",
    "@vueuse/nuxt": "^12.0.0",
    "h3-compression": "^1.0.1",
    "nuxt": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.0",
    "vue-router": "^5.0.6",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@lhci/cli": "^0.15.1",
    "@nuxt/eslint": "^1.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.8"
  }
}
